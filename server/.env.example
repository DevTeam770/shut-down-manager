# מערכת ניהול השבתות — קובץ קונפיגורציה
# העתיקו ל-.env ושנו לפי הצורך. כל השדות אופציונליים (יש ברירות מחדל).

# פורט ההאזנה של השרת
PORT=3000

# נתיב קובץ מסד הנתונים (SQLite)
# DB_PATH=./data/shutdown-manager.db

# תיקיית גיבויים אוטומטיים (נשמרים 14 אחרונים)
# BACKUP_DIR=./data/backups

# שעת הגיבוי הלילי (0-23)
BACKUP_HOUR=2

# שעת התזכורת היומית למי שטרם הגיב להשבתה (0-23)
REMINDER_HOUR=9

# תוקף התחברות בימים
JWT_EXPIRES_DAYS=7

# רמת לוגים: debug / info / warn / error
LOG_LEVEL=info

# קבצים מצורפים להשבתה
# UPLOAD_DIR=./data/uploads
MAX_FILE_MB=25
MAX_FILES_PER_SHUTDOWN=20

# ═══════════════════════════════════════════════════════════════════
# [INTEGRATION: closed-network] חיבורים לרשת הסגורה — רדומים עד שממלאים
# ═══════════════════════════════════════════════════════════════════

# ── מייל (Exchange/SMTP) ── פעיל רק כש-SMTP_HOST מוגדר.
# נשלח מייל על: השבתה חדשה, שינוי תאריך, קיבוע סופי, תזכורת יומית,
# הודעת מנהלה לכולם, והודעת מנהל בצ'אט (למשתמשים עם כתובת מייל).
# SMTP_HOST=mail.corp.local
# SMTP_PORT=25
# SMTP_FROM=shutdown-manager@corp.local
# SMTP_USER=
# SMTP_PASS=

# ── Active Directory (שליפת/אימות משתמשים) ── פעיל רק כש-LDAP_URL מוגדר.
# דורש בנוסף: npm i ldapts -w server, ומימוש הפונקציה ב-server/src/services/directory.js
# (ראו [INTEGRATION: closed-network] שם). admin/לינור נשארים מקומיים תמיד.
# LDAP_URL=ldap://dc1.corp.local:389
# LDAP_BASE_DN=DC=corp,DC=local
# LDAP_UPN_SUFFIX=@corp.local
# LDAP_REQUIRED_GROUP=

# ── Outlook (יומן) ── זמין תמיד, אין צורך בהגדרה: /api/calendar/my.ics

# סוד ה-JWT נוצר אוטומטית בהרצה ראשונה ונשמר כאן — אין צורך למלא ידנית
# JWT_SECRET=

# סוד ה-JWT נוצר אוטומטית בהרצה ראשונה ונשמר כאן — אין צורך למלא ידנית
# JWT_SECRET=
